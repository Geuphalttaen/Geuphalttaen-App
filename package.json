{
  "name": "geuphalttaen-new-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false"
  },
  "dependencies": {
    "@react-native-seoul/kakao-login": "^5.4.2",
    "@tanstack/react-query": "^5.100.11",
    "axios": "^1.16.1",
    "expo": "~54.0.33",
    "expo-apple-authentication": "^55.0.13",
    "expo-location": "^55.1.10",
    "expo-router": "^55.0.14",
    "expo-secure-store": "^55.0.14",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "^1.27.2",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-svg": "^15.15.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@types/react-native-maps": "^0.24.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
